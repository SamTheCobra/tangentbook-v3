# ─── Required — get these before running ──────────────────────────────────────
FRED_API_KEY=your_fred_key_here
# Get free key: https://fred.stlouisfed.org/docs/api/api_key.html

EIA_API_KEY=your_eia_key_here
# Get free key: https://www.eia.gov/opendata/register.php

ANTHROPIC_API_KEY=your_anthropic_key_here
# Get key: https://console.anthropic.com

# ─── App config ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./tangentbook.db
FEED_REFRESH_INTERVAL_MINUTES=60

# ─── Optional — leave blank to disable, add later to unlock ───────────────────
# POLYGON_API_KEY=         # polygon.io — $29/mo, real-time prices + options flow
# CRUNCHBASE_API_KEY=      # crunchbase.com — $49/mo, startup funding signals
# ALPHA_VANTAGE_API_KEY=   # alphavantage.co — free fallback for equity prices

# ─── NEVER commit your actual .env file ───────────────────────────────────────
# This .env.example is safe to commit (no real keys).
# Your .env file with real keys must stay on your machine only.
# It is already in .gitignore.
